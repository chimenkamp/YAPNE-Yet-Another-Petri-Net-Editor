    { "id": "a39", "source": "t_close_admit",     "target": "p_end", "weight": 1, "type": "regular", "points": [], "label": "1" },
    { "id": "a40", "source": "t_close_discharge",  "target": "p_end", "weight": 1, "type": "regular", "points": [], "label": "1" }
